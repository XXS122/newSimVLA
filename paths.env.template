# SimVLA 路径配置文件
# 训练前根据本机实际路径修改，脚本启动时自动加载

# SmolVLM 模型路径（留空则从 HuggingFace 自动下载）
SIMVLA_SMOLVLM_MODEL=""

# VLABench 数据目录（RLDS/TFRecord 格式）
SIMVLA_VLABENCH_DATA="./datasets/vlabench/data/1.0.0"

# VLABench 代码仓库路径（评估时使用）
SIMVLA_VLABENCH_CODE=""

# 模型 checkpoint 保存根目录（子目录会自动以时间戳命名）
SIMVLA_OUTPUT_DIR="./runs"

# 评估结果保存目录
SIMVLA_EVAL_RESULTS="./eval_results"

# GPU 配置
SIMVLA_CUDA_DEVICES="0,1,2,3"
SIMVLA_NUM_GPUS="4"
